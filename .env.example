# Application
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# API (optional overrides)
# API_HOST=0.0.0.0
# APP_PORT — Host port when using Docker Compose (maps host to container 8000). Also binds Uvicorn when set (see docker-compose environment override for containers).
APP_PORT=8000

# Database — async PostgreSQL URL (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://appuser:apppass@localhost:5432/research_db

# OpenAI — required for live LLM calls (use a test key in CI)
OPENAI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.1

# Cost controls (USD)
MAX_DAILY_COST_USD=10.0
MAX_REQUEST_COST_USD=2.0

# Agents
AGENT_TIMEOUT_SECONDS=120
MAX_PARALLEL_AGENTS=3

# CORS — comma-separated origins, empty = none in production
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
